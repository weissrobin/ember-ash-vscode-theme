{
  "name": "Ember and Ash",
  "type": "dark",
  "colors": {
    "editor.background": "#1d1f20",
    "editorLineNumber.foreground": "#828292",
    "editorCursor.foreground": "#ffffff",
    "editorIndentGuide.background1": "#3a3c3f",
    "statusBar.border": "#1d1f20",
    "statusBar.background": "#1d1f20",
    "sideBar.background": "#1d1f20",
    "sideBar.border": "#1d1f20",
    "titleBar.border": "#1d1f20",
    "titleBar.activeBackground": "#1d1f20",
    "tab.activeBorderTop": "#d4a0aa",
    "editorGroupHeader.tabsBackground": "#1d1f20",
    "editorGroupHeader.border": "#1d1f20",
    "terminal.background": "#1d1f20",
    "terminal.foreground": "#dddcf1",
    "terminal.ansiBlack": "#1e1e2e",
    "terminal.ansiRed": "#e78b96",
    "terminal.ansiGreen": "#0dbc79",
    "terminal.ansiYellow": "#f4b89b",
    "terminal.ansiBlue": "#7391b1",
    "terminal.ansiMagenta": "#bda5bb",
    "terminal.ansiCyan": "#c5d2de",
    "terminal.ansiWhite": "#e7e7ff",
    "terminal.ansiBrightBlack": "#666666",
    "terminal.ansiBrightRed": "#e78b96",
    "terminal.ansiBrightGreen": "#23d18b",
    "terminal.ansiBrightYellow": "#f4b89b",
    "terminal.ansiBrightBlue": "#7391b1",
    "terminal.ansiBrightMagenta": "#bda5bb",
    "terminal.ansiBrightCyan": "#c5d2de",
    "terminal.ansiBrightWhite": "#e7e7ff",
    "activityBar.background": "#1d1f20",
    "menu.selectionBackground": "#bb3e00",
    "activityBar.activeBorder": "#f4b89b",
    "activityBar.foreground": "#f4b89b",
    "activityBar.inactiveForeground": "#ffffff66"
  },
  "tokenColors": [
    {
      "name": "Ember & Ash Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "unused.comment",
        "comment.block"
      ],
      "settings": {
        "foreground": "#7A8C7D"
      }
    },
    {
      "name": "Variables & Attributes",
      "scope": [
        "variable",
        "entity.name.variable",
        "meta.definition.variable",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#dddcf1"
      }
    },
    {
      "name": "Support Variables & Classes",
      "scope": [
        "support.variable",
      ],
      "settings": {
        "foreground": "#c5d2de"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#e7e7ff"
      }
    },
    {
      "name": "Keywords & Tags",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#7391b1"
      }
    },
    {
      "name": "Functions & Declarations",
      "scope": [
        "entity.name.function",
        "support.function",
        "entity.name.type.class",
        "entity.name.type.interface",
        "punctuation.definition.heading.markdown",
        "entity.name.section.markdown",
        "entity.other.keyframe-offset.percentage.css"
      ],
      "settings": {
        "foreground": "#e78b96"
      }
    },
    {
      "name": "Types",
      "scope": [
        "support.type",
        "entity.name.type",
        "entity.other.attribute-name.class.css",
        "support.class"
      ],
      "settings": {
        "foreground": "#fcd199"
      }
    },
    {
      "name": "CSS Constant & Property Values",
      "scope": [
        "meta.property-value.css",
      ],
      "settings": {
        "foreground": "#CE9178",
      }
    },
    {
      "name": "Methods & Properties",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name",
        "meta.property.name"
      ],
      "settings": {
        "foreground": "#bda5bb"
      }
    },
    {
      "name": "Strings & Numbers",
      "scope": [
        "string",
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#f4b89b"
      }
    },
    {
      "name": "Operators & Delimiters",
      "scope": [
        "keyword.operator",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#9090aa"
      }
    }
  ]
}